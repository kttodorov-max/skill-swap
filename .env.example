# Copy to .env for local development:
#   cp .env.example .env
#
# Supabase CLI / server-side (no VITE_ prefix – NOT sent to the browser)
SUPABASE_URL=https://xsmzmmvtdrvfobljimym.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
#
# Frontend (Vite – only VITE_ variables are available in import.meta.env)
VITE_SUPABASE_URL=https://xsmzmmvtdrvfobljimym.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
#
# Netlify: Site settings → Environment variables → Production
#   VITE_SUPABASE_URL
#   VITE_SUPABASE_ANON_KEY
#   (Do NOT add SUPABASE_SERVICE_ROLE_KEY to Netlify!)
#
# Supabase Dashboard → Authentication → URL Configuration
#   Site URL:        https://YOUR-SITE.netlify.app
#   Redirect URLs:   http://localhost:5173/**
#                    https://YOUR-SITE.netlify.app/**
#
# Demo admin (after seed migration in Supabase SQL Editor):
